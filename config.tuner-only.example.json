{
  "icecast": {
    "base_url": "http://127.0.0.1:8888",
    "source_user": "source",
    "source_password": "CHANGE_ME",
    "metadata_user": "admin",
    "metadata_password": "CHANGE_ME_ADMIN"
  },
  "update": {
    "interval_seconds": 600,
    "dry_run": false
  },
  "outside": {
    "enabled": false
  },
  "tuner": {
    "enabled": true,
    "mount_name": "tuner",
    "interval_seconds": 5,
    "api_url": "http://127.0.0.1:8080/api",
    "title_template": "South-east Cracow: {freq} MHz | RDS: {ps} | ST: {station} | ERP: {power} | Dist: {distance} | Signal: {signal}"
  },
  "title_mode": "classic"
}
